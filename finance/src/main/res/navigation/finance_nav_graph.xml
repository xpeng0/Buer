<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:startDestination="@id/watchlistFragment"
    android:id="@+id/finance_nav_graph">

    <fragment
        android:id="@+id/watchlistFragment"
        android:name="com.cscyxp.finance.watchlist.ui.fragment.WatchlistFragment"
        android:label="Finance">
        <action android:id="@+id/action_watchlistFragment_to_searchFragment"
            app:destination="@id/searchFragment"/>
        <action android:id="@+id/action_watchlistFragment_to_detailFragment"
            app:destination="@id/detailFragment"/>
    </fragment>

    <fragment
        android:id="@+id/searchFragment"
        android:name="com.cscyxp.finance.search.ui.fragment.SearchFragment"
        android:label="Search">
        <action android:id="@+id/action_searchFragment_to_detailFragment"
            app:destination="@id/detailFragment"/>
    </fragment>

    <fragment
        android:id="@+id/detailFragment"
        android:name="com.cscyxp.finance.details.ui.StockDetailFragment"
        android:label="Detail">

        <argument
            android:name="stockKey"
            app:argType="com.cscyxp.finance.entity.StockKey" />
    </fragment>


</navigation>