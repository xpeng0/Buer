<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:paddingHorizontal="15dp"
    android:paddingVertical="15dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/tv_stock_name"
        android:text="中证500"
        android:textSize="16sp"
        android:textColor="#000000"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tv_stock_tag"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:background="@drawable/bg_stock_tag"
        android:paddingHorizontal="6dp"
        android:paddingVertical="2dp"
        android:textSize="10sp"
        app:layout_constraintBottom_toBottomOf="@id/tv_stock_name"
        app:layout_constraintStart_toEndOf="@id/tv_stock_name"
        app:layout_constraintTop_toTopOf="@id/tv_stock_name"
        tools:text="沪深"
        tools:textColor="#E64A19"
        tools:backgroundTint="#FBE9E7" />


    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/tv_stock_symbol"
        android:text="000905"
        android:textSize="14sp"
        android:textColor="#A0A0A5"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/tv_stock_name"
        app:layout_constraintStart_toStartOf="parent"/>

    <ImageView
        android:id="@+id/iv_toggle_add"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:padding="8dp"
        android:background="@drawable/bg_btn_circle"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:src="@drawable/ic_add_round_24"
        tools:tint="#000000"
        tools:backgroundTint="#F0F0F0" />

</androidx.constraintlayout.widget.ConstraintLayout>