<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:paddingVertical="10dp"
    android:layout_height="wrap_content">


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/ll_stock_info"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="vertical">


            <TextView
                android:layout_width="80dp"
                android:layout_height="24dp"
                android:id="@+id/tv_stock_name"
                android:gravity="center_vertical"
                android:text="TELA"
                android:autoSizeTextType="uniform"
                android:autoSizeMaxTextSize="17sp"
                android:autoSizeMinTextSize="11sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="#000000"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/tv_stock_symbol"
            android:text="000001"
            android:textSize="10sp"
            android:textColor="@color/textTertiary"
            app:layout_constraintTop_toBottomOf="@id/tv_stock_name"
            app:layout_constraintStart_toStartOf="@id/tv_stock_name"
            android:layout_marginTop="2dp"/>


            <com.cscyxp.xpviews.TrendLineView
                android:id="@+id/lv_trend_minute"
                android:layout_width="180dp"
                android:layout_height="30dp"
                android:layout_marginStart="5dp"
                app:layout_constraintStart_toEndOf="@id/tv_stock_name"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>



            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:id="@+id/tv_today_percent"
                android:text="+3.67%"
                android:textSize="13sp"
                android:textColor="#DC4848"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>


    </androidx.constraintlayout.widget.ConstraintLayout>




</LinearLayout>