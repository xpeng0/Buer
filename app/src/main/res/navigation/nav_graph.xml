<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:startDestination="@id/homeFragment"
    android:id="@+id/nav_graph">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.cscyxp.buer.home.ui.HomeFragment"
        android:label="Home">
        <action
            android:id="@+id/action_homeFragment_to_transactionFragment"
            app:destination="@id/transactionFragment" />
        <action
            android:id="@+id/action_homeFragment_to_finance"
            app:destination="@id/finance_nav_graph" />
    </fragment>

    <fragment
        android:id="@+id/transactionFragment"
        android:name="com.cscyxp.buer.TransactionFragment"
        android:label="Bill">
        <action
            android:id="@+id/action_transactionFragment_to_addFragment"
            app:destination="@id/addFragment" />
    </fragment>

    <fragment
        android:id="@+id/addFragment"
        android:name="com.cscyxp.buer.AddFragment"
        android:label="Detail">
    </fragment>

    <fragment
        android:id="@+id/chartFragment"
        android:name="com.cscyxp.buer.ChartFragment"
        android:label="Chart">
        <action
            android:id="@+id/action_chartFragment_to_categoryChartFragment"
            app:destination="@id/categoryChartFragment" />
    </fragment>

    <fragment
        android:id="@+id/categoryChartFragment"
        android:name="com.cscyxp.buer.CategoryChartFragment"
        android:label="CategoryChart">
        <argument
            android:name="categoryId"
            app:argType="long"
            android:defaultValue="-1L"/>
    </fragment>

    <include app:graph="@navigation/finance_nav_graph"/>

</navigation>